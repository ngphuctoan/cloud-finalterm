$ORIGIN docker.localhost.
$TTL 3600

@ IN SOA ns1.docker.localhost. admin.docker.localhost. (
  2026041401 ; Serial (in date format YYYYMMDD)
  3600       ; Refresh
  600        ; Retry
  604800     ; Expire
  3600       ; Min TTL
)

@    IN NS ns1.docker.localhost.
ns1  IN A  10.0.0.2
@    IN A  10.0.0.3
*    IN A  10.0.0.3
